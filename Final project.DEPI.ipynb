<span class="n">null_percent</span> <span class="o">=</span> <span class="p">(</span><span class="n">df</span><span class="o">.</span><span class="n">isnull</span><span class="p">()</span><span class="o">.</span><span class="n">sum</span><span class="p">()</span> <span class="o">/</span> <span class="nb">len</span><span class="p">(</span><span class="n">df</span><span class="p">)</span> <span class="o">*</span> <span class="mi">100</span><span class="p">)</span><span class="o">.</span><span class="n">round</span><span class="p">(</span><span class="mi">2</span><span class="p">)</span>

<span class="n">null_summary</span> <span class="o">=</span> <span class="n">pd</span><span class="o">.</span><span class="n">DataFrame</span><span class="p">({</span>
    <span class="s1">'Null Count'</span><span class="p">:</span> <span class="n">null_counts</span><span class="p">,</span>
    <span class="s1">'Null %'</span><span class="p">:</span> <span class="n">null_percent</span>
<span class="p">})</span>

<span class="n">null_summary</span> <span class="o">=</span> <span class="n">null_summary</span><span class="p">[</span><span class="n">null_summary</span><span class="p">[</span><span class="s1">'Null Count'</span><span class="p">]</span> <span class="o">&gt;</span> <span class="mi">0</span><span class="p">]</span>
<span class="n">null_summary</span> <span class="o">=</span> <span class="n">null_summary</span><span class="o">.</span><span class="n">sort_values</span><span class="p">(</span><span class="s1">'Null Count'</span><span class="p">,</span> <span class="n">ascending</span><span class="o">=</span><span class="kc">False</span><span class="p">)</span>

<span class="n">null_summary</span>
</pre></div>
