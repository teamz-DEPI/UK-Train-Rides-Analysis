      <span class="p">)</span>
      <span class="o">.</span><span class="n">sort_values</span><span class="p">(</span><span class="s2">"Total_Revenue"</span><span class="p">,</span> <span class="n">ascending</span><span class="o">=</span><span class="kc">False</span><span class="p">)</span>
      <span class="o">.</span><span class="n">round</span><span class="p">(</span><span class="mi">2</span><span class="p">)</span>
