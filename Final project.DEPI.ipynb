<div class="jp-CodeMirrorEditor jp-Editor jp-InputArea-editor" data-type="inline">
<div class="cm-editor cm-s-jupyter">
<div class="highlight hl-ipython3"><pre><span></span><span class="n">missing_actual</span> <span class="o">=</span> <span class="n">df</span><span class="p">[</span><span class="n">df</span><span class="p">[</span><span class="s1">'Actual Arrival Time'</span><span class="p">]</span><span class="o">.</span><span class="n">isnull</span><span class="p">()]</span>
<span class="n">all_cancelled</span> <span class="o">=</span> <span class="p">(</span><span class="n">missing_actual</span><span class="p">[</span><span class="s1">'Journey Status'</span><span class="p">]</span> <span class="o">==</span> <span class="s1">'Cancelled'</span><span class="p">)</span><span class="o">.</span><span class="n">all</span><span class="p">()</span>
<span class="nb">print</span><span class="p">(</span><span class="sa">f</span><span class="s1">'All missing Actual Arrival Times correspond to Cancelled journeys? </span><span class="si">{</span><span class="n">all_cancelled</span><span class="si">}</span><span class="s1"> '</span><span class="p">)</span>
</pre></div>
</div>
</div>
</div>
