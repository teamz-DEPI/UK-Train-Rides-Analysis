<span class="nb">print</span><span class="p">(</span><span class="s1">'Final "Reason for Delay" categories:'</span><span class="p">)</span>
<span class="nb">print</span><span class="p">(</span><span class="n">df</span><span class="p">[</span><span class="s1">'Reason for Delay'</span><span class="p">]</span><span class="o">.</span><span class="n">value_counts</span><span class="p">())</span>
</pre></div>
