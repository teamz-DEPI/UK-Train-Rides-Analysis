      <span class="o">.</span><span class="n">groupby</span><span class="p">(</span><span class="s2">"Departure Station"</span><span class="p">)</span>
      <span class="o">.</span><span class="n">agg</span><span class="p">(</span><span class="n">Disruptions</span> <span class="o">=</span> <span class="p">(</span><span class="s2">"Journey Status"</span><span class="p">,</span> <span class="s2">"count"</span><span class="p">))</span>
